	<column name="module_srl"   type="bigint"  size="11"  notnull="notnull" index="idx_module_srl" />
	<column name="document_srl" type="bigint"  size="11"  notnull="notnull" index="idx_document_srl" />
	<column name="action"       type="varchar" size="10"  notnull="notnull" />
	<column name="status"       type="varchar" size="10"  notnull="notnull" default="pending" index="idx_status" />
	<column name="message"      type="text"    size="0"   />
	<column name="regdate"      type="char"    size="14"  notnull="notnull" />
	<column name="last_update"  type="char"    size="14"  />
	<column name="item_type"    type="varchar" size="10"  notnull="notnull" default="document" index="idx_item_type" />
	<column name="comment_srl"  type="bigint"  size="11"  notnull="notnull" default="0" index="idx_comment_srl" />
</table>
