<query id="updateLogStatus" action="update">
	<tables>
		<table name="es_search_log" />
	</tables>
	<columns>
		<column name="status"      var="status"      notnull="notnull" />
		<column name="message"     var="message" />
		<column name="last_update" var="last_update" notnull="notnull" />
	</columns>
	<conditions>
		<condition operation="equal" column="log_srl" var="log_srl" filter="number" notnull="notnull" />
	</conditions>
</query>
