<query id="getCountByTypeAndStatus" action="select">
	<tables>
		<table name="es_search_log" />
	</tables>
	<columns>
		<column name="count(*)" alias="count" />
	</columns>
	<conditions>
		<condition operation="equal" column="status" var="status" notnull="notnull" />
		<condition operation="equal" column="item_type" var="item_type" notnull="notnull" pipe="and" />
	</conditions>
</query>
