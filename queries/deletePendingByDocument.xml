<query id="deletePendingByDocument" action="delete">
	<tables>
		<table name="es_search_log" />
	</tables>
	<conditions>
		<condition operation="equal" column="document_srl" var="document_srl" filter="number" notnull="notnull" />
		<condition operation="equal" column="status" var="status" default="pending" notnull="notnull" pipe="and" />
	</conditions>
</query>
