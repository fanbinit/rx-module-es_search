<query id="getAllCommentSrls" action="select">
	<tables>
		<table name="comments" />
	</tables>
	<columns>
		<column name="comment_srl" />
		<column name="module_srl" />
	</columns>
	<conditions>
		<condition operation="equal" column="status" var="status" filter="number" notnull="notnull" />
		<condition operation="in" column="module_srl" var="module_srl" filter="number" pipe="and" />
		<condition operation="excess" column="comment_srl" var="from_comment_srl" filter="number" pipe="and" />
	</conditions>
	<navigation>
		<index var="sort_index" default="comment_srl" order="asc" />
		<list_count var="list_count" default="200" />
		<page var="page" default="1" />
	</navigation>
</query>
