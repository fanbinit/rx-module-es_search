<query id="insertLog" action="insert">
	<tables>
		<table name="es_search_log" />
	</tables>
	<columns>
		<column name="log_srl"      var="log_srl"      filter="number" notnull="notnull" />
		<column name="module_srl"   var="module_srl"   filter="number" notnull="notnull" />
		<column name="document_srl" var="document_srl" filter="number" notnull="notnull" />
		<column name="action"       var="action"       notnull="notnull" />
		<column name="status"       var="status"       default="pending" notnull="notnull" />
		<column name="regdate"      var="regdate"      notnull="notnull" />
		<column name="item_type"    var="item_type"    default="document" notnull="notnull" />
		<column name="comment_srl"  var="comment_srl"  filter="number" default="0" notnull="notnull" />
	</columns>
</query>
