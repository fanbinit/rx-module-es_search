<query id="getPendingLogs" action="select">
	<tables>
		<table name="es_search_log" />
	</tables>
	<columns>
		<column name="*" />
	</columns>
	<conditions>
		<condition operation="equal" column="status" var="status" default="pending" notnull="notnull" />
	</conditions>
	<navigation>
		<index var="sort_index" default="regdate" order="asc" />
		<list_count var="list_count" default="50" />
		<page var="page" default="1" />
	</navigation>
</query>
